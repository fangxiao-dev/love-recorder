<view class="page-shell">
  <view class="card hero-card">
    <view class="eyebrow-row">
      <view class="eyebrow">{{entryLabel}}</view>
      <view class="state-pill">{{stateLabel}}</view>
    </view>
    <view class="title">{{moduleName}}</view>
    <view class="status-text">{{primaryStatusText}}</view>
    <view class="subtitle">{{secondaryStatusText}}</view>
  </view>

  <view class="card">
    <view class="calendar-heading">
      <view class="section-title">周期日历</view>
      <view class="mode-switch">
        <view class="mode-pill {{calendarMode === 'cycle-window' ? 'mode-pill-active' : ''}}" data-mode="cycle-window" bindtap="onCalendarModeTap">周期窗</view>
        <view class="mode-pill {{calendarMode === 'month' ? 'mode-pill-active' : ''}}" data-mode="month" bindtap="onCalendarModeTap">月视图</view>
      </view>
    </view>

    <view wx:if="{{calendarMode === 'cycle-window' && cycleWindow}}" class="calendar-panel" bindtouchmove="onCalendarTouchMove" bindtouchend="onCalendarTouchEnd">
      <view class="calendar-toolbar">
        <button class="mini-nav-btn" data-start-date="{{cycleWindow.previousStartDate}}" bindtap="onCycleWindowStep">上一周</button>
        <view class="calendar-range">{{cycleWindow.startDate}} - {{cycleWindow.endDate}}</view>
        <button class="mini-nav-btn" data-start-date="{{cycleWindow.nextStartDate}}" bindtap="onCycleWindowStep">下一周</button>
      </view>

      <view class="jump-row">
        <view class="jump-chip" data-target="today" bindtap="onCycleJumpTap">Today</view>
        <view class="jump-chip" data-target="lastCycle" bindtap="onCycleJumpTap">Last cycle</view>
        <view class="jump-chip" data-target="nextPrediction" bindtap="onCycleJumpTap">Next prediction</view>
      </view>

      <view class="weekday-row">
        <block wx:for="{{weekdayLabels}}" wx:key="*this">
          <view class="weekday-cell">{{item}}</view>
        </block>
      </view>

      <block wx:for="{{cycleWindow.weeks}}" wx:key="id" wx:for-item="week">
        <view class="calendar-week">
          <block wx:for="{{week.days}}" wx:key="id" wx:for-item="day">
            <view
              class="calendar-day cycle-window-day {{day.isInSelectedRange ? 'is-selected-range' : ''}} {{day.isSelected ? 'is-selected' : ''}} {{day.isPeriod ? 'is-period' : ''}} {{day.isPredicted ? 'is-predicted' : ''}} {{day.isToday ? 'is-today' : ''}} {{day.periodRole !== 'none' ? 'period-' + day.periodRole : ''}} {{day.predictionRole !== 'none' ? 'prediction-' + day.predictionRole : ''}}"
              hover-class="none"
              data-date="{{day.date}}"
              data-record-id="{{day.recordId}}"
              data-cycle-id="{{day.cycleId}}"
              bindtap="onCalendarDayTap"
              bindlongpress="onCalendarDayLongPress"
            >
              <view class="day-number">{{day.dayLabel}}</view>
              <view class="day-dot {{day.hasMarker ? 'day-dot-visible' : ''}}"></view>
              <view wx:if="{{day.isSelectionAnchor}}" class="anchor-ring"></view>
            </view>
          </block>
        </view>
      </block>
    </view>

    <view wx:if="{{calendarMode === 'month' && monthView}}" class="calendar-panel">
      <view class="calendar-toolbar">
        <button class="mini-nav-btn" data-month-key="{{monthView.previousMonthKey}}" bindtap="onMonthStep">上个月</button>
        <view class="calendar-range">{{monthView.monthLabel}}</view>
        <button class="mini-nav-btn" data-month-key="{{monthView.nextMonthKey}}" bindtap="onMonthStep">下个月</button>
      </view>

      <view class="weekday-row">
        <block wx:for="{{weekdayLabels}}" wx:key="*this">
          <view class="weekday-cell">{{item}}</view>
        </block>
      </view>

      <block wx:for="{{monthView.weeks}}" wx:key="id" wx:for-item="week">
        <view class="calendar-week">
          <block wx:for="{{week.days}}" wx:key="id" wx:for-item="day">
            <view
              class="calendar-day month-day {{day.isInSelectedRange ? 'is-selected-range' : ''}} {{day.isSelected ? 'is-selected' : ''}} {{day.isCurrentMonth ? '' : 'is-outside-month'}} {{day.isPeriod ? 'is-period' : ''}} {{day.isPredicted ? 'is-predicted' : ''}} {{day.isToday ? 'is-today' : ''}} {{day.periodRole !== 'none' ? 'period-' + day.periodRole : ''}} {{day.predictionRole !== 'none' ? 'prediction-' + day.predictionRole : ''}}"
              data-date="{{day.date}}"
              data-record-id="{{day.recordId}}"
              data-cycle-id="{{day.cycleId}}"
              bindtap="onCalendarDayTap"
            >
              <view class="day-number">{{day.dayLabel}}</view>
              <view class="day-dot {{day.hasMarker ? 'day-dot-visible' : ''}}"></view>
            </view>
          </block>
        </view>
      </block>
    </view>

      <view class="timeline-legend">
      <view class="legend-item"><text class="legend-dot legend-special"></text>特殊</view>
      <view class="legend-item"><text class="legend-dot legend-period"></text>经期区间</view>
      <view class="legend-item"><text class="legend-dot legend-predicted"></text>预测窗口</view>
      <view class="legend-item"><text class="legend-dot legend-today"></text>今天</view>
    </view>

    <view class="inline-panel">
      <view wx:if="{{isRangeSelectionMode}}" class="panel-block">
        <view class="panel-title">批量编辑</view>
        <view class="panel-copy">长按起点后滑动刷选。起点未选中时为批量选中，起点已选中时为批量取消；未退出前可单点某天微调。</view>
        <view class="range-meta">当前模式：{{selectionMode.dragMode === 'deselect' ? '批量取消' : '批量选中'}}</view>
        <view class="range-meta">触达日期：{{selectionMode.selectedDates.length}} 天</view>
        <view class="panel-actions">
          <button class="panel-btn panel-btn-secondary" bindtap="onRangeCancel">取消</button>
          <button class="panel-btn panel-btn-primary" bindtap="onRangeSave">保存批量编辑</button>
        </view>
      </view>

      <view wx:elif="{{selectedDatePanel}}" class="panel-block">
        <view class="panel-date">{{selectedDatePanel.selectedDate}}</view>
        <view class="panel-title">{{selectedDatePanel.title}}</view>
        <view class="panel-copy">{{selectedDatePanel.description}}</view>
        <view wx:if="{{selectedDatePanel.cycleDay}}" class="range-meta">经期第 {{selectedDatePanel.cycleDay}} 天</view>
        <view class="panel-actions">
          <button
            class="panel-btn panel-btn-primary"
            data-action="{{selectedDatePanel.primaryAction.key}}"
            bindtap="onSelectedPanelAction"
          >
            {{selectedDatePanel.primaryAction.label}}
          </button>
        </view>
        <view class="state-chip-row">
          <block wx:for="{{selectedDatePanel.stateActions}}" wx:key="key">
            <view
              class="state-chip {{item.active ? 'state-chip-active' : ''}}"
              data-action="{{item.key}}"
              bindtap="onSelectedPanelAction"
            >
              {{item.label}}
            </view>
          </block>
        </view>
        <view class="attribute-grid">
          <view class="attribute-field">
            <view class="attribute-label">流量</view>
            <picker mode="selector" range="{{flowOptions}}" value="{{panelFlowIndex}}" data-field="flow" bindchange="onPanelPickerChange">
              <view class="attribute-value">{{flowOptions[panelFlowIndex] || '未填写'}}</view>
            </picker>
          </view>
          <view class="attribute-field">
            <view class="attribute-label">疼痛</view>
            <picker mode="selector" range="{{painOptions}}" value="{{panelPainIndex}}" data-field="pain" bindchange="onPanelPickerChange">
              <view class="attribute-value">{{painOptions[panelPainIndex] || '未填写'}}</view>
            </picker>
          </view>
          <view class="attribute-field">
            <view class="attribute-label">颜色</view>
            <picker mode="selector" range="{{colorOptions}}" value="{{panelColorIndex}}" data-field="color" bindchange="onPanelPickerChange">
              <view class="attribute-value">{{colorOptions[panelColorIndex] || '未填写'}}</view>
            </picker>
          </view>
        </view>
        <view class="attribute-field attribute-field-notes">
          <view class="attribute-label">备注</view>
          <textarea class="panel-textarea" value="{{panelNotes}}" bindinput="onPanelNotesInput" bindblur="onPanelNotesBlur" placeholder="可留空" />
        </view>
        <view class="panel-subactions">
          <view
            class="panel-link"
            data-action="{{selectedDatePanel.clearAction.key}}"
            bindtap="onSelectedPanelAction"
          >
            {{selectedDatePanel.clearAction.label}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">更多</view>
    <view class="meta">模块实例：{{moduleInstanceId}}</view>
    <view class="action-row">
      <button class="nav-btn" bindtap="goToHistory">查看历史记录</button>
    </view>
  </view>
</view>
