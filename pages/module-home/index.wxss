.card {
  border: 2rpx solid rgba(194, 131, 105, 0.15);
}

.hero-card {
  background: linear-gradient(180deg, rgba(255, 247, 240, 0.98), rgba(255, 255, 255, 0.98));
}

.eyebrow-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.eyebrow {
  font-size: 24rpx;
  color: #9c7b6b;
  letter-spacing: 2rpx;
}

.state-pill {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(59, 38, 29, 0.08);
  color: #5d4035;
  font-size: 22rpx;
}

.status-text {
  margin-top: 24rpx;
  font-size: 46rpx;
  font-weight: 600;
  color: #2f1e17;
}

.meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7d695e;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b261d;
}

.timeline-scroll {
  margin-top: 24rpx;
  white-space: nowrap;
}

.timeline-row {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.timeline-day {
  width: 88rpx;
  padding: 16rpx 0;
  border-radius: 24rpx;
  background: #f7efe9;
  text-align: center;
  color: #8b7062;
}

.timeline-day.is-recorded {
  background: #d9896f;
  color: #fffaf7;
}

.timeline-day.is-predicted {
  box-shadow: inset 0 0 0 2rpx #e3b59d;
}

.timeline-day.is-today {
  transform: translateY(-6rpx);
}

.timeline-month {
  font-size: 20rpx;
}

.timeline-number {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.timeline-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #7d695e;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 8rpx;
  border-radius: 999rpx;
}

.legend-recorded {
  background: #d9896f;
}

.legend-predicted {
  border: 2rpx solid #e3b59d;
}

.legend-today {
  background: #3b261d;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.quick-btn {
  background: #fff7f2;
  color: #5d4035;
  border: 2rpx solid rgba(217, 137, 111, 0.22);
  border-radius: 20rpx;
  font-size: 28rpx;
}

.quick-btn-primary {
  background: #3b261d;
  color: #fff;
  border-color: transparent;
}

.action-row {
  margin-top: 20rpx;
}

.nav-btn {
  width: 100%;
  background: #3b261d;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}
