page {
  background: #fff7f2;
  color: #2d2a26;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(73, 52, 38, 0.08);
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.4;
}

.subtitle {
  margin-top: 16rpx;
  color: #7a6b5f;
  font-size: 28rpx;
  line-height: 1.6;
}
